tan.mean <- aggregate(Tan$`N.NH4.mg.L`, by = list(Treatment = Tan$Treatment), FUN = mean, na.rm = TRUE)
names(tan.mean)[2] <- "mean"
tan.mean$volume.applied <- c(1.33/dat$dfc.area)
tan.mean$volume.applied <- c(1.33/dfc.area)
#Chamber Area#
tan.mean$dfc.area <- (0.7/2)**2 * 3.14 #m^2
tan.mean$volume.applied <- c(1.33)
tan.mean$tan.applied <- tan.mean$volume.applied/tan$dfc.area
tan.mean$tan.applied <- tan.mean$volume.applied/tan.mean$dfc.area
View(tan.mean)
View(dat)
# Calculate TAN fractional loss using total TAN valve
