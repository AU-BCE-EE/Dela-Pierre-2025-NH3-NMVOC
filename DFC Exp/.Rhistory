#Calculation of total flux over time#
# Calculate the rolling average of NH3_flux with a window of 2#
dat$flux.treat <- rollapplyr(dat$NH3.flux, 2, mean, fill = NA)
dat$flux.treat[is.na(dat$flux.treat)] <- dat$NH3.flux[1]
#Calculation of total flux over time, time from start to last start (19 x 8 min)#
dat$flux.time <- dat$flux.tr * 152
#Cumulative emissions#
dat <- mutate(group_by(dat, treatment, group), cum.emis = cumsum(flux.time))
# Ensure the required libraries are loaded
library(dplyr)
library(ggplot2)
library(zoo)
# Assuming 'dat' is your main data, which includes the NH3 flux values and treatment info
# Step 1: Calculate cumulative flux using mintegrate function
source("functions/mintegrate.R")
# Apply mintegrate for cumulative flux over time
dat$flux.treat <- mintegrate(dat$NH3.flux, dat$elapsed.time)
# Step 2: Calculate total flux over time (time from start to last start)
dat$flux.time_mintegrate <- dat$flux.treat * 152
# Step 3: Calculate rolling average of NH3 flux with a window of 2 for comparison
dat$flux.rolling <- rollapplyr(dat$NH3.flux, 2, mean, fill = NA)
# Replace NA values with the first flux value
dat$flux.rolling[is.na(dat$flux.rolling)] <- dat$NH3.flux[1]
# Step 4: Calculate total flux over time for the rolling average method
dat$flux.time_rolling <- dat$flux.rolling * 152
# Step 5: Calculate cumulative emissions for rolling average approach
dat$cum.emis_rolling <- cumsum(dat$flux.time_rolling)
# Step 6: Create a comparison plot of cumulative emissions using mintegrate vs rolling
cumulative_comparison_plot <- ggplot(dat, aes(x = elapsed.time)) +
geom_line(aes(y = cum.emis_rolling, color = "Rolling Average"), size = 1) +
geom_line(aes(y = cumsum(dat$flux.time_mintegrate), color = "Mintegrate"), size = 1, linetype = "dashed") +
labs(
title = "Comparison of Cumulative Emissions (Mintegrate vs Rolling Average)",
x = "Elapsed Time (hours)",
y = expression(paste(NH[3], " Cumulative Emissions (g NH"[3], "-N * min"^-1, " * m"^-2, ")")),
color = "Method"
) +
theme_minimal() +
theme(
axis.title = element_text(size = 14),
axis.text = element_text(size = 12),
plot.title = element_text(size = 16, hjust = 0.5),
legend.title = element_text(size = 14),
legend.text = element_text(size = 12)
) +
scale_color_manual(values = c("Rolling Average" = "blue", "Mintegrate" = "red"))
# Display the plot
print(cumulative_comparison_plot)
# Step 1: Calculate cumulative emissions using the mintegrate method
source("functions/mintegrate.R")
# Apply mintegrate for cumulative flux over time
dat$flux.treat <- mintegrate(dat$NH3.flux, dat$elapsed.time)
# Calculate total flux over time for mintegrate
dat$flux.time_mintegrate <- dat$flux.treat * 152
# Calculate cumulative emissions for mintegrate
dat$cum.emis_mintegrate <- cumsum(dat$flux.time_mintegrate)
# Step 2: Calculate rolling average of NH3 flux with a window of 2 for comparison
dat$flux.rolling <- rollapplyr(dat$NH3.flux, 2, mean, fill = NA)
# Replace NA values with the first flux value
dat$flux.rolling[is.na(dat$flux.rolling)] <- dat$NH3.flux[1]
# Calculate total flux over time for the rolling average method
dat$flux.time_rolling <- dat$flux.rolling * 152
# Calculate cumulative emissions for rolling average
dat$cum.emis_rolling <- cumsum(dat$flux.time_rolling)
# Step 3: Summarize cumulative emissions by treatment for both methods
cum_emis_summary_mintegrate <- dat %>%
group_by(treatment) %>%
summarise(cum.emis_mintegrate = max(cum.emis_mintegrate, na.rm = TRUE))
cum_emis_summary_rolling <- dat %>%
group_by(treatment) %>%
summarise(cum.emis_rolling = max(cum.emis_rolling, na.rm = TRUE))
# Step 4: Combine both summaries into one dataframe for easier plotting
cum_emis_summary <- left_join(cum_emis_summary_mintegrate, cum_emis_summary_rolling, by = "treatment")
# Step 5: Create bar plot for cumulative emissions using mintegrate method
plot_mintegrate <- ggplot(cum_emis_summary, aes(x = treatment, y = cum.emis_mintegrate, fill = treatment)) +
geom_bar(stat = "identity", position = "dodge") +
labs(
title = "Cumulative Emissions by Treatment (Mintegrate Method)",
x = "Treatment",
y = expression(paste("Cumulative Emissions (g NH"[3], "-N * min"^-1, " * m"^-2, ")"))
) +
theme_minimal() +
theme(
axis.title = element_text(size = 14),
axis.text = element_text(size = 12),
plot.title = element_text(size = 16, hjust = 0.5),
legend.title = element_text(size = 14),
legend.text = element_text(size = 12),
axis.text.x = element_text(angle = 45, hjust = 1)
) +
scale_fill_viridis_d()
# Step 6: Create bar plot for cumulative emissions using rolling average method
plot_rolling <- ggplot(cum_emis_summary, aes(x = treatment, y = cum.emis_rolling, fill = treatment)) +
geom_bar(stat = "identity", position = "dodge") +
labs(
title = "Cumulative Emissions by Treatment (Rolling Average Method)",
x = "Treatment",
y = expression(paste("Cumulative Emissions (g NH"[3], "-N * min"^-1, " * m"^-2, ")"))
) +
theme_minimal() +
theme(
axis.title = element_text(size = 14),
axis.text = element_text(size = 12),
plot.title = element_text(size = 16, hjust = 0.5),
legend.title = element_text(size = 14),
legend.text = element_text(size = 12),
axis.text.x = element_text(angle = 45, hjust = 1)
) +
scale_fill_viridis_d()
