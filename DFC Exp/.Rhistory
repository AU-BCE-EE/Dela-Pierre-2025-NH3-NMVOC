)
)
dat <- rbind(valve_data)
#Rename vocs
dat <- dat %>%
rename(
voc1 = methanol,
voc2 = H2S,
voc3 = X4.Methylphenol,
voc4 = acetic_acid,
voc5 = butanoic_acid,
voc6 = pentanoic_acid,
voc7 = propanoic_acid,
voc8 = acetladheyde,
voc9 = formic_acid,
voc10 = methanthiol,
voc11 = acetone,
voc12 = trimethylamine,
voc13 = dimethyl_sulfide,
voc14 = isopren,
voc15 = butanone,
voc16 = benzen,
voc17 = butandion,
voc18 = phenol,
voc19 = X4_ethyl_phenol,
voc20 = methyl_indole
)
View(dat)
