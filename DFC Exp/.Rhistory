`18` = 'Mp',
`19` = '5.7'
),
group = case_when(
valve %in% c(2, 6, 14) ~ 'No acid',
valve %in% c(3, 10, 15) ~ 'Low acid',
valve %in% c(4, 11, 17) ~ 'Medium acid',
valve %in% c(7, 13, 19) ~ 'High acid',
