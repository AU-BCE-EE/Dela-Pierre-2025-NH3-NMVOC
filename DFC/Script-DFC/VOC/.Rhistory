# Background and Grid
panel.grid = element_line(color = "gray84", linewidth = 0.4),
panel.grid.minor = element_blank(),
panel.border = element_rect(color = "gray60", fill = NA, linewidth = 0.5)
) +
scale_x_continuous(
limits = c(0, 119),
breaks = seq(0, 120, by = 20)
) +
guides(
fill = guide_legend(nrow = 1)
)
print(voc.plot)
